{
    "server": {
        "description": "监听的服务器",
        "type": "string",
        "hint": "请输入Gotify服务器地址"
    },
    "token": {
        "description": "客户端token",
        "type": "string",
        "hint": "请输入client_token（非application_token）"
    },
    "bindings": {
        "description": "转发绑定",
